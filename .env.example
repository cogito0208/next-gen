# ===========================================
# 환경 변수 템플릿
# ===========================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요
# cp .env.example .env

# ===========================================
# 데이터베이스 설정
# ===========================================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=kmtls_groupware

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# 애플리케이션 설정
# ===========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ===========================================
# 인증 설정
# ===========================================
# JWT Secret (최소 32자 이상의 랜덤 문자열)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# ===========================================
# OAuth 설정
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback

# Microsoft Azure AD
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/microsoft/callback

# Kakao Work
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/kakao/callback

# ===========================================
# 외부 API 연동
# ===========================================
# GitHub
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Gmail API
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/v1/mail/oauth/callback

# Microsoft Graph API (Outlook)
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret

# ===========================================
# 클라우드 스토리지
# ===========================================
# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=kmtls-groupware

# Google Cloud Storage
GCS_PROJECT_ID=your_gcs_project_id
GCS_BUCKET=kmtls-groupware
GCS_KEY_FILE=./config/gcs-key.json

# ===========================================
# 알림 서비스
# ===========================================
# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_fcm_project_id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ===========================================
# 결제 서비스
# ===========================================
# 토스페이먼츠
TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key

# ===========================================
# 모니터링 & 로깅
# ===========================================
# Sentry (에러 추적)
SENTRY_DSN=your_sentry_dsn

# Log Level
LOG_LEVEL=debug

# ===========================================
# MCP (Model Context Protocol)
# ===========================================
# MCP 서버 사용을 위한 환경 변수
MCP_FILESYSTEM_PATH=/Users/haeyoung/next_gen_01
MCP_GIT_REPOSITORY=/Users/haeyoung/next_gen_01

# ===========================================
# 프론트엔드 (Next.js) 설정
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ===========================================
# 기타 설정
# ===========================================
# CORS 허용 도메인 (쉼표로 구분)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# 파일 업로드 제한 (MB)
MAX_FILE_SIZE=10

# 세션 시크릿
SESSION_SECRET=your-session-secret-change-this

# ===========================================
# 개발 도구
# ===========================================
# Database GUI
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/kmtls_groupware

# Prisma
# DATABASE_URL="postgresql://postgres:your_password@localhost:5432/kmtls_groupware?schema=public"
